# 팀메모리 환경변수 템플릿
# 이 파일을 복사해서 .env 로 이름 바꾸고, 실제 값 채워서 사용하세요.
# .env 파일은 절대 GitHub에 올리지 마세요! (.gitignore에 추가 필수)

# ────────────────────────────────────────────
# Azure OpenAI API
# Azure Portal → 만든 OpenAI 리소스 → 키 및 엔드포인트 에서 복사
# ────────────────────────────────────────────
AZURE_OPENAI_API_KEY=여기에_Azure_키1_입력
AZURE_OPENAI_ENDPOINT=https://여기에_리소스이름.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# ────────────────────────────────────────────
# MySQL DB
# ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=team_memory
DB_USER=root
DB_PASSWORD=여기에_비밀번호_입력

# ────────────────────────────────────────────
# Chroma DB
# ────────────────────────────────────────────
CHROMA_DIR=./chroma_db

# ────────────────────────────────────────────
# FastAPI
# ────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
