# Copy this file to .env on the VM and replace every CHANGE_ME value.
# Use URL-safe values for POSTGRES_PASSWORD because it is embedded in DATABASE_URL.
# Example secret generator: openssl rand -hex 32

POSTGRES_DB=azag_db
POSTGRES_USER=azag
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

JWT_SECRET_KEY=CHANGE_ME_RANDOM_JWT_SECRET
JWT_EXPIRE_HOURS=8

APP_BIND_ADDRESS=0.0.0.0
APP_PORT=8002
FRONTEND_ORIGINS=http://localhost:8002
MAX_UPLOAD_BYTES=26214400

# Start with disabled. Change to azure after the base deployment is healthy.
AI_PROVIDER=disabled
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=16
AZURE_OPENAI_MAX_RETRIES=3
