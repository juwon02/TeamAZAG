# Copy this file to .env and replace placeholders locally.
# Do not commit .env because it contains the database password.
DATABASE_URL=postgresql+psycopg://AZAG_DB_USER:CHANGE_ME@AZURE_VM_PUBLIC_IP:5432/azag_db

# If SSL is enabled in the PostgreSQL server and DBeaver connection, use:
# DATABASE_URL=postgresql+psycopg://AZAG_DB_USER:CHANGE_ME@AZURE_VM_PUBLIC_IP:5432/azag_db?sslmode=require

# Azure OpenAI
AI_PROVIDER=azure
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=your_api_version_here
AZURE_OPENAI_CHAT_DEPLOYMENT=your_chat_deployment_name_here
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your_embedding_deployment_name_here
