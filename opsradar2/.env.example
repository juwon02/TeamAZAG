# Copy this file to .env and change only local values.
# Never commit .env because it contains secrets.

DATABASE_URL=postgresql+asyncpg://AZAG_DB_USER:CHANGE_ME@LINUX_DB_HOST:5432/azag_db
DB_SCHEMA=opsradar2

# React/Vite dev server origins allowed to call FastAPI directly.
# If the React dev server uses Vite proxy, same-origin /api calls also work.
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8010,http://localhost:8010

# If PostgreSQL requires SSL, append ?ssl=require to DATABASE_URL.

# AI provider: disabled | azure
AI_PROVIDER=azure

# Azure OpenAI settings
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=your_api_version_here
AZURE_OPENAI_CHAT_DEPLOYMENT=your_chat_deployment_name_here
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your_embedding_deployment_name_here

# Vector store
FAISS_INDEX_PATH=data/faiss/index.faiss
