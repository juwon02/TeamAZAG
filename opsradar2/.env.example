# Copy this file to .env and replace only the placeholder values.
# Do not commit .env because it contains secrets.

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/opsradar

# AI Provider: disabled | azure
AI_PROVIDER=azure

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=your_api_version_here
AZURE_OPENAI_CHAT_DEPLOYMENT=your_chat_deployment_name_here
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your_embedding_deployment_name_here

# Vector DB
CHROMA_HOST=localhost
CHROMA_PORT=8001
